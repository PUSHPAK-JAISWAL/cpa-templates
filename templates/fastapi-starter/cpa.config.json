{
  "name": "fastapi-starter",
  "customOptions": [
    {
      "key": "apiPrefix",
      "type": "string",
      "message": "API URL prefix (e.g. /api/v1)",
      "default": "/api/v1"
    },
    {
      "key": "enableCors",
      "type": "boolean",
      "message": "Enable CORS middleware",
      "default": true
    }
  ]
}
